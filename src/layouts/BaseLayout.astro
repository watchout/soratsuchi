---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'そらつち農場｜埼玉県小川町の有機農場',
  description = '埼玉県小川町で、農薬や化学肥料に頼らない循環型の有機農業に取り組む、そらつち農場の公式サイトです。',
} = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="logo" href="/">そらつち農場</a>
        <nav class="nav" aria-label="主要ナビゲーション">
          <a href="/about/">農場について</a>
          <a href="/farming/">農法とこだわり</a>
          <a href="/products/">育てているもの</a>
          <a href="/events/">体験・田んぼ教室</a>
          <a href="/journal/">畑だより</a>
          <a class="button" href="/contact/">お問い合わせ</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <h2>そらつち農場</h2>
          <p class="small">埼玉県比企郡小川町で営農する有機農場。土を育て、種をつなぎ、地域資源がめぐる農を目指します。</p>
        </div>
        <div>
          <p class="small">このサイトは公開情報をもとにした初期版です。氏名表記、販売品目、イベント詳細、写真、問い合わせ先は公開前に農場側で確認してください。</p>
        </div>
      </div>
    </footer>
  </body>
</html>
